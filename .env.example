# URL du webhook n8n — requis pour la soumission du formulaire
VITE_N8N_WEBHOOK_URL=

# URL d'embed Google Calendar — optionnel
# Obtenir depuis : Google Calendar → Paramètres → Intégrer l'agenda → src de l'<iframe>
# Exemple : https://calendar.google.com/calendar/embed?src=YOUR_CALENDAR_ID&ctz=Europe%2FParis
VITE_GOOGLE_CALENDAR_SRC=

VITE_OPENROUTER_API_KEY=           # Clé OpenRouter pour le chatbot Paul
VITE_N8N_PAUL_WEBHOOK_URL=         # Webhook n8n dédié au workflow Paul
